{%- set user = salt['pillar.get']('default:OMV_RSYNC_CRONUSER', 'root') -%}
{% set prefix = salt['pillar.get']('default:OMV_RSYNC_CRONSCRIPT_PREFIX', 'rsync-') %}
{%- set spc = ' ' -%}
{%- set host = job.dest.uri.split(':')[0].split('@')[-1] -%}
{%- set islocal = host.endswith('.local') if host else false -%}

{{ pillar['headers']['multiline'] -}}
[Unit]
Description=Service for job {{ prefix ~ job.uuid }}
After=network-online.target avahi-daemon.service
Wants=network-online.target avahi-daemon.service

[Service]
Type=oneshot
Environment="SHELL=/bin/sh"
Environment="PATH=/usr/local/sbin:/usr/local/bin:/sbin:/bin:/usr/sbin:/usr/bin"
User={{ user }}
{%- if islocal %}
ExecStartPre=nc -z {{ host }} 873
ExecStartPre=/bin/sh -c 'until nc -z {{ host }} 873; do sleep 5; done'
{%- endif %}
ExecStart=/bin/sh -c '{{ script_path }} 
{%- if not job.sendemail | to_bool -%}
{{ spc }}>/dev/null 2>&1
{%- else -%}
{{ spc }}2>&1 | mail -E -s "Task{{ ' - ' ~ job.comment | replace('\n', ' ') if job.comment | length > 0 else '' }}" -a "From: Systemd Timer <{{ user }}>" {{ user }} >/dev/null 2>&1
{%- endif -%}'

